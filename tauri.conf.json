{
  "$schema": "https://tauri.app/v1/schema.json",
  "productName": "CutForge",
  "version": "0.1.0",
  "identifier": "com.acorx.cutforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../src-tauri/target/release"
  },
  "app": {
    "windows": [
      {
        "title": "CutForge",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}